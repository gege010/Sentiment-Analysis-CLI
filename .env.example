# ============================================
# X.com Authentication (Cookie Method - Recommended)
# ============================================
# Option 1: Auto-export from Chrome
# Run: python scripts/export_cookies.py --save
#
# Option 2: Manual cookies from Chrome DevTools
# Login to x.com → F12 → Application → Cookies → x.com
X_COOKIE_AUTH_TOKEN=your_auth_token_here
X_COOKIE_CT0=your_csrf_token_here
X_COOKIE_GUEST_ID=your_guest_id_here

# ============================================
# Alternative: Username/Password (May be blocked)
# ============================================
X_USERNAME=your_username_or_email
X_PASSWORD=your_password

# ============================================
# Optional Settings
# ============================================
DEFAULT_TWEET_COUNT=200
MAX_RETRIES=3